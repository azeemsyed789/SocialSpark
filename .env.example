# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/megatron
PGDATABASE=megatron
PGHOST=localhost
PGPORT=5432
PGUSER=username
PGPASSWORD=password

# Redis Configuration (for job queues)
REDIS_URL=redis://localhost:6379

# Authentication
SESSION_SECRET=your-super-secret-session-key-here
ISSUER_URL=https://replit.com/oidc

# Replit Configuration
REPL_ID=your-repl-id
REPLIT_DOMAINS=your-app-domain.replit.dev

# AI Services
GEMINI_API_KEY=your-gemini-api-key-here
HEYGEN_API_KEY=your-heygen-api-key-here
STABLE_DIFFUSION_KEY=your-stable-diffusion-api-key-here

# Social Media Platform APIs
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
YT_API_KEY=your-youtube-api-key
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token

# External Webhooks & Integrations
BUFFER_WEBHOOK_URL=https://hook.us2.make.com/your-buffer-webhook
MAKE_WEBHOOK_URL=https://hook.us2.make.com/your-make-webhook

# Proxy Configuration
PROXY_POOL_URL=https://your-proxy-provider.com/api
PROXY_API_KEY=your-proxy-api-key

# File Storage (S3 Compatible)
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET=your-s3-secret-key
S3_BUCKET=megatron-assets
S3_REGION=us-east-1

# Application Configuration
NODE_ENV=development
PORT=5000

# Optional: Monitoring & Analytics
SENTRY_DSN=your-sentry-dsn-for-error-tracking
ANALYTICS_API_KEY=your-analytics-service-key

# Optional: Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000

# Feature Flags
ENABLE_AB_TESTING=true
ENABLE_AI_GENERATION=true
ENABLE_AUTO_POSTING=true
ENABLE_ANALYTICS=true
